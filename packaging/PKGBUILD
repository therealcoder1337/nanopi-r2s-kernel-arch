# SPDX-License-Identifier: GPL-2.0-or-later
# NanoPi R2S kernel, aligned with Arch Linux ARM linux-aarch64.

pkgname=linux-nanopi-r2s-minimal
pkgbase=linux-nanopi-r2s-minimal
pkgver=7.1.1
pkgrel=1
_srcname=linux-7.1
_desc="NanoPi R2S router profile (ALARM-aligned)"
arch=('aarch64')
url="https://github.com/torvalds/linux"
license=('GPL-2.0-only')
depends=('coreutils' 'kmod' 'mkinitcpio>=0.7')
optdepends=('linux-firmware-realtek: RTL8153 USB Ethernet firmware')
provides=("linux=${pkgver}" "linux-aarch64=${pkgver}" "KSMBD-MODULE" "WIREGUARD-MODULE")
conflicts=('linux' 'linux-aarch64')
options=('!strip' '!debug')
install=linux-nanopi-r2s-minimal.install

makedepends=(
    'kmod' 'bc' 'dtc' 'python' 'openssl' 'libelf'
    'aarch64-linux-gnu-gcc' 'aarch64-linux-gnu-binutils'
)

# Sources filled by scripts/prepare-build-dir.sh (CI / local build)
source=(
    "${_srcname}.tar.xz"
    "patch-${pkgver}.xz"
    'config.merged'
    'linux-nanopi-r2s-minimal.preset'
    'mkinitcpio.linux-nanopi-r2s-minimal.conf'
    'r8152-led-config-from-of.patch'
    'rk3328-nanopi-r2s-r8153-led-data.patch'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

export ARCH=arm64
export CROSS_COMPILE="${CROSS_COMPILE:-aarch64-linux-gnu-}"
export LOCALVERSION=""

# NanoPi R2S only — avoid installing the full Rockchip DTB tree (~50+ MiB).
_r2s_dtb=rockchip/rk3328-nanopi-r2s.dtb
_r2s_dtb_path=arch/arm64/boot/dts/${_r2s_dtb}

prepare() {
    cd "$srcdir"
    rm -rf "$_srcname"
    tar -xf "${_srcname}.tar.xz"
    cd "$_srcname"

    echo "-${pkgrel}" > localversion.10-pkgrel
    echo "-nanopi-r2s-minimal" > localversion.20-pkgname

    if [[ -f ../patch-${pkgver} ]]; then
        patch -p1 -N < "../patch-${pkgver}"
    fi
    patch -p1 -N < "${srcdir}/r8152-led-config-from-of.patch"
    patch -p1 -N < "${srcdir}/rk3328-nanopi-r2s-r8153-led-data.patch"

    cp "${srcdir}/config.merged" ./.config
    make ARCH=arm64 CROSS_COMPILE="$CROSS_COMPILE" olddefconfig
}

build() {
    cd "$_srcname"
    local _jobs
    _jobs="${MAKEFLAGS#-j}"
    [[ "$_jobs" =~ ^[0-9]+$ ]] || _jobs="$(nproc)"

    make ARCH=arm64 CROSS_COMPILE="$CROSS_COMPILE" -j"$_jobs" \
        prepare Image modules
    make ARCH=arm64 CROSS_COMPILE="$CROSS_COMPILE" -j"$_jobs" \
        DTC_FLAGS="-@" "$_r2s_dtb"
    make -s ARCH=arm64 CROSS_COMPILE="$CROSS_COMPILE" kernelrelease > version
}

package() {
    pkgdesc="Linux kernel for NanoPi R2S - ${_desc}"
    cd "$_srcname"
    local kernver="$(<version)"
    local modulesdir="$pkgdir/usr/lib/modules/$kernver"

    install -Dm644 arch/arm64/boot/Image -t "${pkgdir}/boot"
    install -Dm644 "$_r2s_dtb_path" "${pkgdir}/boot/dtbs/${_r2s_dtb}"
    make INSTALL_MOD_PATH="$pkgdir/usr" ARCH=arm64 CROSS_COMPILE="$CROSS_COMPILE" \
        INSTALL_MOD_STRIP=1 DEPMOD=/doesnt/exist modules_install
    rm -f "$modulesdir"/build

    local _subst="
        s|%PKGBASE%|${pkgbase}|g
        s|%KERNVER%|${kernver}|g
    "
    sed "$_subst" "${srcdir}/linux-nanopi-r2s-minimal.preset" |
        install -Dm644 /dev/stdin "${pkgdir}/etc/mkinitcpio.d/${pkgbase}.preset"
    install -Dm644 "${srcdir}/mkinitcpio.linux-nanopi-r2s-minimal.conf" \
        "${pkgdir}/etc/mkinitcpio.linux-nanopi-r2s-minimal.conf"

    install -d "${pkgdir}/usr/lib/initcpio"
    echo "trigger mkinitcpio" > "${pkgdir}/usr/lib/initcpio/.${pkgbase}-${pkgver}"
}
