SPDX-License-Identifier: GPL-2.0-only

Read RTL8152/RTL8153 LED configuration from devicetree when present.

Based on OpenWrt's R2S LED configuration support:
https://lists.openwrt.org/pipermail/openwrt-devel/2021-February/033822.html

Original patch:
From: David Bauer <mail@david-bauer.net>
Subject: [PATCH] net: usb: r8152: add LED configuration from OF
Signed-off-by: David Bauer <mail@david-bauer.net>

Adapted for the ALARM 7.0 r8152 driver in this package.

diff --git a/drivers/net/usb/r8152.c b/drivers/net/usb/r8152.c
--- a/drivers/net/usb/r8152.c
+++ b/drivers/net/usb/r8152.c
@@ -11,6 +11,7 @@
 #include <linux/hex.h>
 #include <linux/phy.h>
 #include <linux/usb.h>
+#include <linux/of.h>
 #include <linux/crc32.h>
 #include <linux/if_vlan.h>
 #include <linux/uaccess.h>
@@ -7011,6 +7012,19 @@ static void rtl_tally_reset(struct r8152 *tp)
 	ocp_write_word(tp, MCU_TYPE_PLA, PLA_RSTTALLY, ocp_data);
 }
 
+static void r8152_led_configuration(struct r8152 *tp)
+{
+	u32 led_data;
+	int ret;
+
+	ret = of_property_read_u32(tp->udev->dev.of_node, "realtek,led-data",
+				   &led_data);
+	if (ret)
+		return;
+
+	ocp_write_word(tp, MCU_TYPE_PLA, PLA_LEDSEL, led_data);
+}
+
 static void r8152b_init(struct r8152 *tp)
 {
 	u32 ocp_data;
@@ -7047,6 +7061,8 @@ static void r8152b_init(struct r8152 *tp)
 	ocp_data = ocp_read_word(tp, MCU_TYPE_USB, USB_USB_CTRL);
 	ocp_data &= ~(RX_AGG_DISABLE | RX_ZERO_EN);
 	ocp_write_word(tp, MCU_TYPE_USB, USB_USB_CTRL, ocp_data);
+
+	r8152_led_configuration(tp);
 }
 
 static void r8153_init(struct r8152 *tp)
@@ -7198,7 +7214,9 @@ static void r8153_init(struct r8152 *tp)
 	default:
 		tp->coalesce = COALESCE_SLOW;
 		break;
 	}
+
+	r8152_led_configuration(tp);
 }

 static void r8153b_init(struct r8152 *tp)
@@ -7277,6 +7295,8 @@ static void r8153b_init(struct r8152 *tp)
 	rtl_tally_reset(tp);
 
 	tp->coalesce = 15000;	/* 15 us */
+
+	r8152_led_configuration(tp);
 }
 
 static void r8153c_init(struct r8152 *tp)
