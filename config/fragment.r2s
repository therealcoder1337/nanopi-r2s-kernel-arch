# NanoPi R2S (RK3328) router profile on top of ALARM linux-aarch64.
# Invariant: this fragment keeps board/router features; trims live in fragment.prune.

# ---------------------------------------------------------------------------
# Kernel identity
# ---------------------------------------------------------------------------
CONFIG_LOCALVERSION=""

# ---------------------------------------------------------------------------
# Ethernet and router datapath
# ---------------------------------------------------------------------------
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_GENERIC=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_USB_RTL8152=y
CONFIG_USB_NET_DRIVERS=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NFT_CT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=y
CONFIG_WIREGUARD=y

# ---------------------------------------------------------------------------
# USB host and storage
# ---------------------------------------------------------------------------
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_HOST=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# ---------------------------------------------------------------------------
# MMC and block storage
# ---------------------------------------------------------------------------
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y

# ---------------------------------------------------------------------------
# Thermal, hwmon, and RTC
# ---------------------------------------------------------------------------
CONFIG_HWMON=y
CONFIG_THERMAL=y
CONFIG_ROCKCHIP_THERMAL=m
CONFIG_SENSORS_PWM_FAN=m
CONFIG_SENSORS_GPIO_FAN=m
CONFIG_SENSORS_INA2XX=m
CONFIG_SENSORS_INA3221=m
CONFIG_RTC_CLASS=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_SYSTOHC=y
CONFIG_RTC_DRV_RK808=m
CONFIG_RTC_DRV_HYM8563=m

# ---------------------------------------------------------------------------
# LEDs and CPU frequency
# ---------------------------------------------------------------------------
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGER_NETDEV=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y

# ---------------------------------------------------------------------------
# Locales and userspace compatibility
# ---------------------------------------------------------------------------
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ASCII=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_SECURITY_LANDLOCK=y
