# ---------------------------------------------------------------------------
# Network and clustered filesystems
# ---------------------------------------------------------------------------
# Keep ext4, FAT/VFAT, exFAT, overlayfs, and FUSE.
CONFIG_BTRFS_FS=n
CONFIG_XFS_FS=n
CONFIG_F2FS_FS=n
CONFIG_REISERFS_FS=n
CONFIG_JFS_FS=n
CONFIG_GFS2_FS=n
CONFIG_OCFS2_FS=n
CONFIG_NILFS2_FS=n
CONFIG_BCACHEFS_FS=n
CONFIG_CEPH_FS=n
CONFIG_CIFS=n
CONFIG_SMB_SERVER=n
CONFIG_NFS_FS=n
CONFIG_NFSD=n
CONFIG_9P_FS=n
CONFIG_AFS_FS=n
CONFIG_CODA_FS=n

# ---------------------------------------------------------------------------
# Storage, SCSI, and ATA
# ---------------------------------------------------------------------------
# Keep MMC/eMMC plus USB storage/UAS from the R2S profile.
# Removed: enterprise RAID, SAS/FC/iSCSI, SATA/PATA, tape/UFS, storage archaeology.
# SCSI_LOWLEVEL=n drops all HBA leaf drivers. USB HDDs/SSDs use USB_STORAGE/UAS
# plus SCSI disk, not libata/AHCI.
CONFIG_SCSI_LOWLEVEL=n
CONFIG_ATA=n
CONFIG_ATA_SFF=n
CONFIG_CHR_DEV_ST=n
CONFIG_CHR_DEV_SCH=n
CONFIG_SCSI_ENCLOSURE=n
CONFIG_RAID_ATTRS=n
CONFIG_SCSI_DH=n
CONFIG_SCSI_SPI_ATTRS=n
CONFIG_SCSI_FC_ATTRS=n
CONFIG_SCSI_ISCSI_ATTRS=n
CONFIG_SCSI_SAS_LIBSAS=n
CONFIG_SCSI_SAS_ATTRS=n
CONFIG_SCSI_SRP_ATTRS=n
CONFIG_ISCSI_TARGET=n
CONFIG_ATA_OVER_ETH=n
# Native SATA controllers not present on NanoPi R2S/RK3328
CONFIG_SATA_HOST=n
CONFIG_SATA_PMP=n
CONFIG_SATA_AHCI=n
CONFIG_SATA_AHCI_PLATFORM=n
CONFIG_SATA_AHCI_SEATTLE=n
CONFIG_SATA_INIC162X=n
CONFIG_SATA_ACARD_AHCI=n
CONFIG_SATA_SIL24=n
# UFS (mobile-SoC storage; RK3328 boots SD/eMMC/USB)
CONFIG_SCSI_UFSHCD=n
CONFIG_SCSI_UFSHCD_PCI=n
CONFIG_SCSI_UFSHCD_PLATFORM=n
CONFIG_SCSI_UFS_QCOM=n
CONFIG_SCSI_UFS_HISI=n

