# NanoPi R2S (RK3328) router trim fragment on top of the R2S profile.
# Invariant: keep the router contract; disable only board-irrelevant surface.
#
# Keep Ethernet+USB-NIC routing, nftables/iptables, WireGuard, IPv6,
# namespaces/cgroups/seccomp/BPF, Landlock, ext4/overlayfs, SD/MMC/eMMC,
# USB storage/UAS, RK3328 thermal/cpufreq, and the USB host path.

# ---------------------------------------------------------------------------
# Non-Rockchip SoC platforms
# ---------------------------------------------------------------------------
CONFIG_ARCH_APPLE=n
CONFIG_ARCH_BCM=n
CONFIG_ARCH_BCM2835=n
CONFIG_ARCH_BCMBCA=n
CONFIG_ARCH_HISI=n
CONFIG_ARCH_MEDIATEK=n
CONFIG_ARCH_MESON=n
CONFIG_ARCH_MVEBU=n
CONFIG_ARCH_NXP=n
CONFIG_ARCH_LAYERSCAPE=n
CONFIG_ARCH_MXC=n
CONFIG_ARCH_QCOM=n
CONFIG_ARCH_SEATTLE=n
CONFIG_ARCH_TEGRA=n
CONFIG_ARCH_VEXPRESS=n
CONFIG_ARCH_XGENE=n
CONFIG_ARCH_SUNXI=n

# RK3328 stays enabled; packaging installs only the NanoPi R2S DTB.

# ---------------------------------------------------------------------------
# ACPI
# ---------------------------------------------------------------------------
# Device-tree-only SBC; keep ARM64 stubs that olddefconfig leaves.
CONFIG_ACPI=n

# ---------------------------------------------------------------------------
# Virtualization and cloud infrastructure
# ---------------------------------------------------------------------------
# Drop built-in virtio users before the umbrella symbols.
CONFIG_KVM=n
CONFIG_KVM_ARM_HOST=n
CONFIG_VIRTUALIZATION=n
CONFIG_VSOCKETS=n
CONFIG_VSOCKETS_DIAG=n
CONFIG_VSOCKETS_LOOPBACK=n
CONFIG_VIRTIO_BLK=n
CONFIG_SCSI_VIRTIO=n
CONFIG_VIRTIO_CONSOLE=n
CONFIG_VIRTIO_PCI=n
CONFIG_VIRTIO_PCI_LEGACY=n
CONFIG_VIRTIO_NET=n
CONFIG_VIRTIO_VSOCKETS=n
CONFIG_VIRTIO_VSOCKETS_COMMON=n
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_INPUT=n
CONFIG_VIRTIO_MMIO=n
CONFIG_VIRTIO_FS=n
CONFIG_HW_RANDOM_VIRTIO=n
CONFIG_CRYPTO_DEV_VIRTIO=n
CONFIG_REMOTEPROC=n
CONFIG_RPMSG_CTRL=n
CONFIG_RPMSG_CHAR=n
CONFIG_RPMSG_QCOM_GLINK_RPM=n
CONFIG_RPMSG_QCOM_SMD=n
CONFIG_RPMSG_QCOM_GLINK_SMEM=n
CONFIG_RPMSG_QCOM_GLINK=n
CONFIG_VIRTIO_MENU=n
CONFIG_VIRTIO=n
CONFIG_VHOST_MENU=n
CONFIG_VFIO=n

# ---------------------------------------------------------------------------
# Wireless, Bluetooth, NFC, and radio
# ---------------------------------------------------------------------------
# NanoPi R2S is used as a wired router.
CONFIG_BT=n
CONFIG_CFG80211=n
CONFIG_MAC80211=n
CONFIG_WLAN=n
CONFIG_NFC=n
CONFIG_RFKILL=n
CONFIG_HAMRADIO=n

# ---------------------------------------------------------------------------
# Niche networking protocols
# ---------------------------------------------------------------------------
# Keep core IPv4/IPv6, netfilter, and WireGuard. PPPoE/direct-DSL-modem
# support is outside this profile.
CONFIG_ATM=n
CONFIG_MPLS=n
CONFIG_NET_9P=n
CONFIG_RDS=n
CONFIG_TIPC=n
CONFIG_OPENVSWITCH=n
CONFIG_IP_VS=n
CONFIG_BATMAN_ADV=n
CONFIG_IEEE802154=n
CONFIG_6LOWPAN=n
CONFIG_L2TP=n
CONFIG_PPTP=n
CONFIG_SLIP=n
CONFIG_PPP=n
CONFIG_PPPOE=n
CONFIG_MPTCP=n

# ---------------------------------------------------------------------------
# Enterprise and non-board NIC vendors
# ---------------------------------------------------------------------------
# Keep Realtek for RTL8153 and STMicro/Synopsys for dwmac/stmmac.
CONFIG_SCSI_BNX2_ISCSI=n
CONFIG_SCSI_BNX2X_FCOE=n
CONFIG_NET_VENDOR_AGERE=n
CONFIG_NET_VENDOR_ALACRITECH=n
